# ============================================
# CONFIGURACIÓN DEL BOT DE TELEGRAM - STARLINK NET
# ============================================

# Token del Bot de Telegram (OBLIGATORIO)
# Obtén este token de @BotFather en Telegram
# EJEMPLO: BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=

# URL del Webhook (se genera automáticamente en Render)
# No necesitas configurar esto manualmente
WEBHOOK_URL=

# Entorno de la aplicación (production/development)
APP_ENV=production

# Modo de depuración (true/false) - Usar false en producción
DEBUG=false

# Nivel de logs: debug, info, warning, error, critical
LOG_LEVEL=info

# IDs de administradores de Telegram (separados por coma)
# Obtén tu ID usando @userinfobot en Telegram
ADMIN_IDS=

# ============================================
# INFORMACIÓN DE LA EMPRESA
# ============================================

# Correo electrónico de contacto
COMPANY_EMAIL=soporte@starlinknet.com

# Teléfono de contacto
COMPANY_PHONE=+58 412-1234567

# Website de la empresa
COMPANY_WEBSITE=https://starlinknet.com

# Dirección física
COMPANY_ADDRESS=Caracas, Venezuela

# Número de WhatsApp (formato: +código país + número)
COMPANY_WHATSAPP=+584121234567
