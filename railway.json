{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "installCommand": "composer install --no-dev --optimize-autoloader",
    "buildCommand": "echo 'Build complete'"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
